{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Details for a potential client inquiry from the growth audit form.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "companyName": { "type": "string" },
        "monthlyRevenue": { "type": "string" },
        "primaryGoal": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "closed"] }
      },
      "required": ["fullName", "email", "primaryGoal"]
    },
    "PortfolioProject": {
      "title": "Portfolio Project",
      "description": "Details of a completed client project for the portfolio showcase.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "category": { "type": "string" },
        "challenge": { "type": "string" },
        "outcome": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["clientName", "category", "challenge", "outcome"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of business inquiries."
    },
    "/portfolio/{projectId}": {
      "schema": "PortfolioProject",
      "description": "Collection of case studies."
    }
  }
}
